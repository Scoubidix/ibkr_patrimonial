# IBKR Gateway
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
TRADING_MODE=paper
IB_PORT=4002

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Strategy thresholds (test mode - relaxed)
RSI_THRESHOLD=50
SMA_MARGIN=0.10
MIN_CASH=50
MIN_ORDER=10
PORTFOLIO_PCT=0.01
CASH_USE_PCT=0.90

# Cron schedule (every 5 min for testing, "30 22 * * *" for prod)
SCAN_CRON=*/5 * * * *
